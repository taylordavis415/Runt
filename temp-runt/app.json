{
  "expo": {
    "name": "Runt",
    "slug": "runt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taylordavis.runt",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "react-native-health",
        {
          "NSHealthShareUsageDescription": "Runt reads your Apple Health data to calculate readiness, recovery, and provide personalized coaching.",
          "NSHealthUpdateUsageDescription": "Runt writes completed workouts and training data to Apple Health."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4b03ebf4-0d81-448d-8e77-265967fd49c4"
      }
    }
  }
}
